NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_your-key
GROQ_AI_KEY=your-groq-api-key

# Server-only Supabase Postgres connection string for the SQL agent.
# Prefer a dedicated read-only Postgres role. Do not prefix this with NEXT_PUBLIC_.
READONLY_DATABASE_URL=postgresql://readonly_user:***@db.your-project-ref.supabase.co:5432/postgres
